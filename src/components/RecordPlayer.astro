---
import recordImage from '../assets/record_circle.webp';
---

<div class="stage" id="stage">

  <div
    class="record"
    aria-hidden="true"
    style={`background-image: url('${recordImage.src}')`}
  ></div>

  <!-- tonearm -->
  <div class="tonearm" aria-hidden="true">
    <svg viewBox="0 0 200 200">
      <defs>
        <linearGradient id="armGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#d8d2c0"/>
          <stop offset="50%" stop-color="#9a9080"/>
          <stop offset="100%" stop-color="#5a5448"/>
        </linearGradient>
        <radialGradient id="pivotGrad" cx="40%" cy="40%">
          <stop offset="0%" stop-color="#3a3530"/>
          <stop offset="60%" stop-color="#1a1815"/>
          <stop offset="100%" stop-color="#0a0a08"/>
        </radialGradient>
        <linearGradient id="cartGrad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#1a1815"/>
          <stop offset="100%" stop-color="#08080a"/>
        </linearGradient>
      </defs>

      <line x1="180" y1="24" x2="58" y2="118" stroke="url(#armGrad)" stroke-width="3.5" stroke-linecap="round"/>
      <line x1="180" y1="24" x2="194" y2="14" stroke="url(#armGrad)" stroke-width="3" stroke-linecap="round"/>
      <circle cx="195" cy="13" r="6" fill="#2a2520" stroke="#0a0a08" stroke-width="0.5"/>
      <circle cx="180" cy="24" r="9" fill="url(#pivotGrad)" stroke="#0a0a08" stroke-width="0.6"/>
      <circle cx="180" cy="24" r="3" fill="#0a0a08"/>

      <g transform="translate(58, 118) rotate(38)">
        <rect x="-12" y="-2" width="22" height="9" rx="1" fill="url(#cartGrad)" stroke="#000" stroke-width="0.4"/>
        <rect x="-10" y="0" width="18" height="2" fill="#3a3530" opacity="0.6"/>
        <line x1="-9" y1="7" x2="-11" y2="11" stroke="#aa8a55" stroke-width="0.8"/>
        <circle cx="-11" cy="11" r="0.8" fill="#f4f1ea"/>
      </g>
    </svg>
  </div>

  <button class="play-btn" id="playBtn" aria-label="Play Rules Without Rulers">
    <svg id="glyph" class="glyph" viewBox="0 0 24 24" aria-hidden="true">
      <polygon points="7,5 7,19 19,12"/>
    </svg>
  </button>

</div>

<div class="counter">
  <span class="time" id="time">00:00</span>
  <span class="total">/ 03:42</span>
  <span class="hint">↑ tap the orange to play</span>
</div>

<!-- audio element — connect src once the mp3 is ready -->
<audio id="track" preload="metadata"></audio>

<style>
  .stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .stage::before {
    content: '';
    position: absolute;
    inset: -8%;
    background: radial-gradient(circle at center, rgba(247, 147, 26, 0.05) 0%, transparent 55%);
    pointer-events: none;
    transition: opacity 0.6s ease;
    opacity: 0.5;
  }
  .stage.is-spinning::before {
    opacity: 1;
  }

  .record {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: no-repeat center / contain;
    transform-origin: center;
    will-change: transform;
    filter: drop-shadow(0 12px 40px rgba(0, 0, 0, 0.6));
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .stage.is-spinning .record {
    animation: spin 1.5s linear infinite;
  }

  .tonearm {
    position: absolute;
    top: -4%;
    right: 2%;
    width: 56%;
    height: 56%;
    pointer-events: none;
    transform-origin: 90% 12%;
    transform: rotate(-22deg);
    transition: transform 1.1s cubic-bezier(0.6, 0.05, 0.3, 1);
    z-index: 4;
  }
  .stage.is-spinning .tonearm {
    transform: rotate(-2deg);
  }
  .tonearm svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) translateX(11.5%);
    width: 13%;
    height: 13%;
    border-radius: 50%;
    background: rgba(247, 147, 26, 0);
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }
  .play-btn:hover {
    transform: translate(-50%, -50%) translateX(11.5%) scale(1.08);
  }
  .play-btn:focus { outline: none; }
  .play-btn:focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: 4px;
  }
  .play-btn .glyph {
    width: 50%;
    height: 50%;
    fill: #ffffff;
    transition: opacity 0.15s ease;
    opacity: 0;
  }
  .stage:hover .play-btn .glyph,
  .play-btn:hover .glyph,
  .play-btn:focus-visible .glyph {
    opacity: 1;
  }
  .stage.is-spinning .play-btn .glyph {
    opacity: 0;
  }
  .stage.is-spinning .play-btn:hover .glyph,
  .stage.is-spinning .play-btn:focus-visible .glyph {
    opacity: 1;
  }

  .counter {
    text-align: center;
    margin-bottom: 3rem;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--dim);
    text-transform: uppercase;
  }
  .counter .time {
    color: var(--accent);
    margin-right: 0.5rem;
  }
  .counter .total { color: var(--dim); }
  .counter .hint {
    display: block;
    margin-top: 0.6rem;
    font-size: 9px;
    letter-spacing: 0.4em;
    color: #3d3d3d;
  }
</style>

<script>
  (function () {
    const stage = document.getElementById('stage') as HTMLElement;
    const btn = document.getElementById('playBtn') as HTMLButtonElement;
    const glyph = document.getElementById('glyph') as SVGElement;
    const timeEl = document.getElementById('time') as HTMLElement;
    const audio = document.getElementById('track') as HTMLAudioElement;

    const PLAY = '<polygon points="7,5 7,19 19,12"/>';
    const PAUSE = '<rect x="6" y="5" width="4" height="14"/><rect x="14" y="5" width="4" height="14"/>';

    function fmt(s: number): string {
      return String(Math.floor(s / 60)).padStart(2, '0') + ':' + String(Math.floor(s) % 60).padStart(2, '0');
    }

    function startSpin(): void {
      stage.classList.add('is-spinning');
      glyph.innerHTML = PAUSE;
      btn.setAttribute('aria-label', 'Pause');
    }

    function stopSpin(): void {
      stage.classList.remove('is-spinning');
      glyph.innerHTML = PLAY;
      btn.setAttribute('aria-label', 'Play');
    }

    /* ── real audio path (when src is set) ─────────────────────── */
    if (audio.src && audio.src !== window.location.href) {
      audio.addEventListener('timeupdate', () => {
        timeEl.textContent = fmt(audio.currentTime);
      });
      audio.addEventListener('ended', () => {
        stopSpin();
        timeEl.textContent = '00:00';
      });

      btn.addEventListener('click', () => {
        if (audio.paused) {
          audio.play();
          startSpin();
        } else {
          audio.pause();
          stopSpin();
        }
      });
      return;
    }

    /* ── dummy counter path (no audio yet) ──────────────────────── */
    let playing = false;
    let sec = 0;
    let tid: ReturnType<typeof setInterval> | null = null;

    btn.addEventListener('click', () => {
      playing = !playing;
      if (playing) {
        startSpin();
        tid = setInterval(() => {
          sec++;
          if (sec > 222) sec = 0;
          timeEl.textContent = fmt(sec);
        }, 1000);
      } else {
        stopSpin();
        if (tid) { clearInterval(tid); tid = null; }
      }
    });
  })();
</script>
